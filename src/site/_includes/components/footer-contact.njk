<script>
(function pkSidebarSync() {
  // Fire after all deferred scripts (Alpine etc.) have settled
  function init() {
    var footer  = document.getElementById('contact');
    var sidebar = document.querySelector('.sidebar');
    if (!footer || !sidebar) return;

    var io = new IntersectionObserver(function(entries) {
      // rootMargin top:120px means sidebar starts fading 120px
      // before the footer top edge hits the viewport bottom —
      // giving the appearance both columns end simultaneously.
      sidebar.classList.toggle('pk-sidebar-end', entries[0].isIntersecting);
    }, {
      rootMargin: '120px 0px 0px 0px',
      threshold: 0
    });

    io.observe(footer);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    // Small delay so Alpine / DG JS doesn't fight us
    setTimeout(init, 80);
  }
})();
</script>
