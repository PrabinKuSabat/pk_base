<!-- JS: add class when title contains ".excalidraw" -->
<script>
(function () {
  try {
    var title = (document.title || '').toString();
    if (title.toLowerCase().indexOf('.excalidraw') !== -1) {
      document.documentElement.classList.add('title-contains-excalidraw');
    }
  } catch (e) { /* noop */ }
})();
</script>

<style>
