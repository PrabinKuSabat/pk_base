SITE_NAME_HEADER=Prabin's KB ~
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://prabins.vercel.app
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=false
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --cursor: pointer; --font-ui-small: 17px; --font-ui-smaller: 14px; } body.theme-light.css-settings-manager { --workspace-background-translucent: #FF000000; } body.theme-dark.css-settings-manager { --workspace-background-translucent: #000000; }
STYLE_SETTINGS_BODY_CLASSES=mod-linux is-frameless is-hidden-frameless obsidian-app theme-light show-ribbon show-view-header highlightr-rounded css-settings-manager pdf-plus-click-embed-to-open-link pdf-plus-backlink-selection-highlight image-captions-enabled is-maximized is-focused minimal-theme minimal-notion-dark minimal-readable minimal-nord-light minimal-light-contrast minimal-dark borders-none colorful-headings colorful-frame colorful-active links-ext-on img-grid minimal-folding chart-default-width table-default-width img-max iframe-default-width map-default-width hide-pdf-embed-toolbar hide-pdf-toolbar-in-hover-editor callouts-default trim-cols checkbox-circle pdf-seamless-on pdf-invert-dark pdf-blend-light sidebar-tabs-default tab-names-off vault-profile-default ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover window-title-off styled-scrollbars default
USE_FULL_RESOLUTION_IMAGES=true
THEME=https://raw.githubusercontent.com/kepano/obsidian-minimal/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgPassFrontmatter=true
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=false
dgShowFileTree=false
dgEnableSearch=false
dgShowToc=true
dgLinkPreview=false
dgShowTags=true